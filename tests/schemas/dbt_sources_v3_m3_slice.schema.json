{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.getdbt.com/dbt/sources/v3.json#dxt-source-freshness-slice",
  "title": "dxt dbt Sources v3 source-freshness compatibility slice",
  "$comment": "Pinned local compatibility slice for dbt Sources v3. Source reference: https://schemas.getdbt.com/dbt/sources/v3.json, checked 2026-06-17. This validates the current dxt source freshness surface: metadata, success results, runtime-error results, criteria, timing, and elapsed_time.",
  "type": "object",
  "additionalProperties": false,
  "required": ["metadata", "results", "elapsed_time"],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dbt_schema_version",
        "dbt_version",
        "generated_at",
        "invocation_id",
        "invocation_started_at",
        "env"
      ],
      "properties": {
        "dbt_schema_version": {"const": "https://schemas.getdbt.com/dbt/sources/v3.json"},
        "dbt_version": {"type": "string"},
        "generated_at": {"type": "string"},
        "invocation_id": {"type": ["string", "null"]},
        "invocation_started_at": {"type": ["string", "null"]},
        "env": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "anyOf": [
          {"$ref": "#/$defs/sourceFreshnessOutput"},
          {"$ref": "#/$defs/sourceFreshnessRuntimeError"}
        ]
      }
    },
    "elapsed_time": {"type": "number"}
  },
  "$defs": {
    "sourceFreshnessRuntimeError": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unique_id", "error", "status"],
      "properties": {
        "unique_id": {"type": "string"},
        "error": {"type": ["string", "integer", "null"]},
        "status": {"const": "runtime error"}
      }
    },
    "sourceFreshnessOutput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unique_id",
        "max_loaded_at",
        "snapshotted_at",
        "max_loaded_at_time_ago_in_s",
        "status",
        "criteria",
        "adapter_response",
        "timing",
        "thread_id",
        "execution_time"
      ],
      "properties": {
        "unique_id": {"type": "string"},
        "max_loaded_at": {"type": "string"},
        "snapshotted_at": {"type": "string"},
        "max_loaded_at_time_ago_in_s": {"type": "number"},
        "status": {"enum": ["pass", "warn", "error", "runtime error"]},
        "criteria": {"$ref": "#/$defs/freshnessThreshold"},
        "adapter_response": {
          "type": "object",
          "propertyNames": {"type": "string"}
        },
        "timing": {
          "type": "array",
          "items": {"$ref": "#/$defs/timingInfo"}
        },
        "thread_id": {"type": "string"},
        "execution_time": {"type": "number"}
      }
    },
    "freshnessThreshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["warn_after", "error_after", "filter"],
      "properties": {
        "warn_after": {
          "anyOf": [{"$ref": "#/$defs/freshnessTime"}, {"type": "null"}]
        },
        "error_after": {
          "anyOf": [{"$ref": "#/$defs/freshnessTime"}, {"type": "null"}]
        },
        "filter": {"type": ["string", "null"]}
      }
    },
    "freshnessTime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["count", "period"],
      "properties": {
        "count": {"type": "integer"},
        "period": {"enum": ["minute", "hour", "day"]}
      }
    },
    "timingInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "started_at", "completed_at"],
      "properties": {
        "name": {"type": "string"},
        "started_at": {"type": ["string", "null"]},
        "completed_at": {"type": ["string", "null"]}
      }
    }
  }
}
